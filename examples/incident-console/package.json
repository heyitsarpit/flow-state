{
  "name": "@flow-state/incident-console",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "browser:install": "playwright install chromium",
    "build": "pnpm check:typescript-mode-proofs && next build",
    "check:typescript-mode-proofs": "pnpm exec tsc -p tsconfig.json --pretty false",
    "dev": "next dev --webpack --hostname 127.0.0.1 --port 5187",
    "test": "cd ../.. && vp test examples/incident-console/src",
    "test:acceptance": "pnpm test:browser",
    "test:browser": "playwright test",
    "test:browser:headed": "playwright test --headed"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.86",
    "clsx": "^2.1.1",
    "effect": "4.0.0-beta.86",
    "flow-state": "workspace:*",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@effect/vitest": "4.0.0-beta.86",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "tailwindcss": "^4.3.2"
  }
}
