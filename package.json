{
  "name": "flow-state-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm build:library && pnpm build:examples",
    "build:examples": "pnpm --filter @flow-state/react-basic build",
    "build:library": "pnpm --filter @flow-state/core build",
    "check": "vp check",
    "check:fix": "vp check --fix",
    "dev": "pnpm --filter @flow-state/react-basic dev",
    "fmt": "vp fmt",
    "fmt:check": "vp fmt --check",
    "format": "pnpm fmt",
    "format:check": "pnpm fmt:check",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "pack": "pnpm --filter @flow-state/core pack",
    "test": "vp test",
    "verify": "pnpm check && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@types/node": "latest",
    "typescript": "7.0.1-rc",
    "vite-plus": "0.2.1"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "packageManager": "pnpm@10.13.1",
  "pnpm": {
    "ignoredBuiltDependencies": [
      "msgpackr-extract"
    ],
    "peerDependencyRules": {
      "allowedVersions": {
        "typescript": "7.0.1-rc"
      }
    }
  }
}
