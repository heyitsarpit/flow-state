{
  "name": "@flow-state/core",
  "version": "0.0.0",
  "private": true,
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vp pack src/index.ts && pnpm prepare:build-output && pnpm check:build-output",
    "check:build-output": "node ./scripts/check-build-output.mjs",
    "check:typescript-mode-proofs": "node ./scripts/check-typescript-mode-proofs.mjs",
    "inspect:local-proof": "node ./scripts/inspect-local-proof.mjs",
    "pack": "vp pack src/index.ts && pnpm prepare:build-output && pnpm check:build-output",
    "prepare:build-output": "node ./scripts/prepare-build-output.mjs",
    "test": "cd ../.. && vp test packages/flow-state/src"
  },
  "dependencies": {
    "@tanstack/store": "0.11.0"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "effect": "4.0.0-beta.86",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "peerDependencies": {
    "effect": "4.0.0-beta.86",
    "react": "^18.0.0 || ^19.0.0"
  }
}
