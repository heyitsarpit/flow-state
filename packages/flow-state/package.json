{
  "name": "flow-state",
  "version": "0.0.0",
  "private": true,
  "bin": {
    "flow-state": "./dist/cli/index.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./react": {
      "types": "./dist/react-entry.d.mts",
      "import": "./dist/react-entry.mjs"
    },
    "./testing": {
      "types": "./dist/testing.d.mts",
      "import": "./dist/testing.mjs"
    },
    "./server": {
      "types": "./dist/server.d.mts",
      "import": "./dist/server.mjs"
    },
    "./inspect": {
      "types": "./dist/inspect.d.mts",
      "import": "./dist/inspect.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "behavior:cli": "node ./scripts/behavior-cli.mjs",
    "build": "pnpm check:cli-source-types && vp pack --logLevel warn --no-report src/index.ts src/react-entry.ts src/testing.ts src/server.ts src/inspect.ts && pnpm prepare:build-output && pnpm check:build-output",
    "check:build-output": "node ./scripts/check-build-output.mjs",
    "check:cli-source-types": "pnpm exec tsc -p tsconfig.json --noEmit",
    "check:typescript-mode-proofs": "node ./scripts/check-typescript-mode-proofs.mjs",
    "inspect:local-proof": "node ./scripts/inspect-local-proof.mjs",
    "pack": "pnpm check:cli-source-types && vp pack --logLevel warn --no-report src/index.ts src/react-entry.ts src/testing.ts src/server.ts src/inspect.ts && pnpm prepare:build-output && pnpm check:build-output",
    "prepare:build-output": "node ./scripts/prepare-build-output.mjs",
    "test": "cd ../.. && vp test packages/flow-state/src"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.86",
    "@tanstack/store": "0.11.0"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "effect": "4.0.0-beta.86",
    "esbuild": "0.28.1",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "peerDependencies": {
    "effect": "4.0.0-beta.86",
    "react": "^18.0.0 || ^19.0.0"
  }
}
